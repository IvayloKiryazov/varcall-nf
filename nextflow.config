manifest {
    name            = 'varcall-nf'
    author          = 'Ivaylo Kiryazov'
    description     = 'A tiny, reproducible DNA variant-calling pipeline (FASTQ -> QC -> align -> call -> report) built with Nextflow DSL2.'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '0.6.0'
}

params {
    input           = "${projectDir}/assets/samplesheet.csv"
    reference       = "${projectDir}/assets/test_data/reference/ref.fa"
    outdir          = 'results'
    caller          = 'bcftools'                 // 'bcftools' | 'freebayes' | 'gatk'
    trim            = true                        // adapter/quality trimming with fastp
    mark_duplicates = true                        // mark PCR/optical duplicates
    filter_expr     = 'QUAL<20 || INFO/DP<10'     // bcftools filter expression (soft filter)

    // Real-data / simulation options (see -profile test_full)
    simulate_reads    = false                     // simulate reads from --reference instead of --input
    sample_id         = 'sim'                      // sample name when simulating
    sim_region_length = 100000                     // bp of the reference to simulate from
    sim_coverage      = 40                         // target depth for simulated reads
    sim_num_snps      = 20                         // number of known SNPs to introduce

    // Optional annotation (off by default; needs a matching SnpEff database)
    annotate  = false
    snpeff_db = 'Escherichia_coli_str_k_12_substr_mg1655_gca_000005845'
}

process {
    cpus   = 2
    memory = '2 GB'
}

profiles {
    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }
    apptainer {
        apptainer.enabled    = true
        apptainer.autoMounts = true
    }
    // Self-contained data bundled in the repo; `-profile test` documents intent and
    // pins the inputs even if a user overrides params elsewhere.
    test {
        params.input     = "${projectDir}/assets/samplesheet.csv"
        params.reference = "${projectDir}/assets/test_data/reference/ref.fa"
    }
    // On-demand real-data run: downloads the E. coli K-12 reference and simulates reads from
    // it. Run with `-profile docker,test_full` (see .github/workflows/test_full.yml).
    test_full {
        params.simulate_reads    = true
        params.reference         = 'https://ftp.ncbi.nlm.nih.gov/genomes/all/GCF/000/005/845/GCF_000005845.2_ASM584v2/GCF_000005845.2_ASM584v2_genomic.fna.gz'
        params.sample_id         = 'ecoli'
        params.sim_region_length = 200000
    }
}

// Execution observability: machine-readable trace (raw units) drives bin/pipeline_metrics.py,
// which turns per-step runtime / CPU / memory into an SLO-style report.
timeline { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/timeline.html" }
report   { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/report.html" }
dag      { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/dag.html" }
trace {
    enabled   = true
    overwrite = true
    raw       = true
    file      = "${params.outdir}/pipeline_info/trace.txt"
    fields    = 'task_id,name,status,exit,realtime,%cpu,peak_rss,peak_vmem,rchar,wchar'
}
