manifest {
    name            = 'varcall-nf'
    author          = 'Ivaylo Kiryazov'
    description     = 'A tiny, reproducible DNA variant-calling pipeline (FASTQ -> QC -> align -> call -> report) built with Nextflow DSL2.'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '0.1.0'
}

params {
    input     = "${projectDir}/assets/samplesheet.csv"
    reference = "${projectDir}/assets/test_data/reference/ref.fa"
    outdir    = 'results'
}

process {
    cpus   = 2
    memory = '2 GB'
}

profiles {
    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }
    // Self-contained data bundled in the repo; `-profile test` documents intent and
    // pins the inputs even if a user overrides params elsewhere.
    test {
        params.input     = "${projectDir}/assets/samplesheet.csv"
        params.reference = "${projectDir}/assets/test_data/reference/ref.fa"
    }
}

timeline { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/timeline.html" }
report   { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/report.html" }
