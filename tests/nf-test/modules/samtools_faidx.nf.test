nextflow_process {

    name "SAMTOOLS_FAIDX"
    script "modules/local/samtools_faidx.nf"
    process "SAMTOOLS_FAIDX"

    test("indexes the reference FASTA") {

        when {
            process {
                """
                input[0] = file("${projectDir}/assets/test_data/reference/ref.fa")
                """
            }
        }

        then {
            assert process.success
            assert path(process.out.fai.get(0)).exists()
            assert process.out.fai.get(0).endsWith(".fai")
        }
    }
}
